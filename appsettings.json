{
  
  "ConnectionStrings": {
    /* * DefaultConnection: Defines the parameters for connecting to the 
       * SQL LocalDB instance. It specifies the server, database name, and 
       * security protocols (Microsoft, 2023).
    */
    "DefaultConnection": "Server=(localdb)\\mssqllocaldb;Database=EventEase_FinalVersion;Trusted_Connection=True;MultipleActiveResultSets=true"
  },
  "Logging": {
    /* * Logging Configuration: Defines the granularity of diagnostic 
       * information recorded by the framework during runtime (Microsoft, 2023).
    */
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  /* * AllowedHosts: A security setting that restricts which hostnames 
     * the application is allowed to respond to (Freeman, 2022).
  */
  "AllowedHosts": "*"
}

