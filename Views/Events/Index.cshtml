@model IEnumerable<CLDV6211_Assignment_Part_1_St10449059.Models.Event>

@{
    ViewData["Title"] = "Index";
}

<h1 class="display-6">Events</h1>

<p>
    @* Anchor Tag Helpers utilize the routing engine to navigate to the Create View (Freeman, 2022) *@
    <a asp-action="Create" class="btn btn-outline-success">Create New Event</a>
</p>

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>
                @* DisplayNameFor extracts the Display attribute from the Event model metadata *@
                @Html.DisplayNameFor(model => model.EventName)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.EventDate)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ImageUrl)
            </th>
            <th>
                @* This represents the Navigation Property link to the Venue model *@
                @Html.DisplayNameFor(model => model.Venue)
            </th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @* Iterative rendering of the Event collection provided by the controller *@
        @foreach (var item in Model)
        {
            <tr>
                <td class="fw-bold">
                    @Html.DisplayFor(modelItem => item.EventName)
                </td>
                <td>
                    @* Formats the date using the standard ASP.NET display template (Microsoft, 2023) *@
                    @Html.DisplayFor(modelItem => item.EventDate)
                </td>
                <td>
                    @* Inline CSS used to prevent the long ImageUrl string from breaking the table layout 
                       by implementing an ellipsis overflow (Coyne, 2021).
                    *@
                    <div style="max-width: 150px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                        @Html.DisplayFor(modelItem => item.ImageUrl)
                    </div>
                </td>
                <td>
                    @* Demonstrates the use of Eager Loading to access related data in a 1:Many relationship *@
                    @Html.DisplayFor(modelItem => item.Venue.Location)
                </td>
                <td>
                    @* CRUD operation links generated with dynamic routing IDs *@
                    <a asp-action="Edit" asp-route-id="@item.EventId">Edit</a> |
                    <a asp-action="Details" asp-route-id="@item.EventId">Details</a> |
                    <a asp-action="Delete" asp-route-id="@item.EventId">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
