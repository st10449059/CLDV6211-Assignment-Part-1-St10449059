@model CLDV6211_Assignment_Part_1_St10449059.Models.Booking

@{
    ViewData["Title"] = "Create";
}

<h1 class="display-6">Create Booking</h1>
<hr />

<div class="row">
    <div class="col-md-6">
        @* The form post action targets the Create method in the BookingsController *@
        <form asp-action="Create">
            @* Displays a summary of validation errors to the user *@
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group mb-3">
                <label asp-for="AttendeeName" class="control-label fw-bold"></label>
                <input asp-for="AttendeeName" class="form-control" placeholder="Enter full name" />
                @* Client-side validation message placeholder *@
                <span asp-validation-for="AttendeeName" class="text-danger"></span>
            </div>

            <div class="form-group mb-4">
                <label asp-for="EventId" class="control-label fw-bold">Select Event</label>
                @*
                   FIXED: Changed asp-items to use ViewData["EventId"] as a SelectList 
                   to match the BookingsController logic.
                *@
                <select asp-for="EventId" class="form-select" asp-items="@(ViewData["EventId"] as SelectList)">
                    <option value="">-- Choose an Event --</option>
                </select>
                <span asp-validation-for="EventId" class="text-danger"></span>
            </div>

            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary px-4 shadow-sm" />
                <a asp-action="Index" class="btn btn-secondary ms-2">Cancel</a>
            </div>
        </form>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @* Includes standard jQuery validation scripts *@
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}