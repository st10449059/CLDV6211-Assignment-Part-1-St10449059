@model CLDV6211_Assignment_Part_1_St10449059.Models.Booking

@{
    ViewData["Title"] = "Create";
}

<h1 class="display-6">Create Booking</h1>

<hr />
<div class="row">
    <div class="col-md-6">
        @* The form post action targets the Create method in the BookingsController (Microsoft, 2023) *@
        <form asp-action="Create">
            @* Displays a summary of validation errors to the user *@
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group mb-3">
                <label asp-for="AttendeeName" class="control-label fw-bold"></label>
                <input asp-for="AttendeeName" class="form-control" placeholder="Enter full name" />
                @* Client-side validation message placeholder (Microsoft, 2023) *@
                <span asp-validation-for="AttendeeName" class="text-danger"></span>
            </div>

            <div class="form-group mb-4">
                <label asp-for="EventId" class="control-label fw-bold">Select Event</label>
                @* The dropdown list is dynamically populated from the database via ViewBag.EventId *@
                <select asp-for="EventId" class="form-select" asp-items="ViewBag.EventId">
                    <option value="">-- Choose an Event --</option>
                </select>
                <span asp-validation-for="EventId" class="text-danger"></span>
            </div>

            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary px-4" />
                <a asp-action="Index" class="btn btn-secondary ms-2">Cancel</a>
            </div>
        </form>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @* Includes standard jQuery validation scripts to handle input checks before submission (Microsoft, 2023) *@
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
