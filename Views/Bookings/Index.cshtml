@model IEnumerable<CLDV6211_Assignment_Part_1_St10449059.Models.Booking>

@{
    ViewData["Title"] = "Index";
}

<h1 class="display-6">Bookings</h1>

<p>
    @* Tag Helpers simplify the generation of URLs for controller actions (Microsoft, 2023) *@
    <a asp-action="Create" class="btn btn-outline-info">Create New Booking</a>
</p>

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>
                @* HTML Helpers extract metadata from the model to display column headers *@
                @Html.DisplayNameFor(model => model.AttendeeName)
            </th>
            <th>
                @* Navigation Property Header *@
                @Html.DisplayNameFor(model => model.Event)
            </th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @* Iterates through the list of bookings provided by the BookingsController *@
        @foreach (var item in Model)
        {
            <tr>
                <td class="fw-bold">
                    @Html.DisplayFor(modelItem => item.AttendeeName)
                </td>
                <td>
                    @* Demonstrates accessing a related entity's property (Microsoft, 2023) *@
                    @Html.DisplayFor(modelItem => item.Event.EventName)
                </td>
                <td>
                    @* Dynamic route IDs are used to target specific records for CRUD actions *@
                    <a asp-action="Edit" asp-route-id="@item.BookingId">Edit</a> |
                    <a asp-action="Details" asp-route-id="@item.BookingId">Details</a> |
                    <a asp-action="Delete" asp-route-id="@item.BookingId">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
