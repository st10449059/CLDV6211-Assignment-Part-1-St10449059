@model CLDV6211_Assignment_Part_1_St10449059.Models.Venue

@{
    ViewData["Title"] = "Create";
}

<h1 class="display-6">Create Venue</h1>

<hr />
<div class="row">
    <div class="col-md-6">
        @* The asp-action helper designates the controller method to handle the form submission (Microsoft, 2023) *@
        <form asp-action="Create">
            @* Provides a summary of validation failures at the top of the form for enhanced UX *@
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group mb-3">
                <label asp-for="VenueName" class="control-label fw-bold"></label>
                <input asp-for="VenueName" class="form-control" placeholder="e.g. Cape Town Stadium" />
                <span asp-validation-for="VenueName" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Location" class="control-label fw-bold"></label>
                <input asp-for="Location" class="form-control" placeholder="e.g. Fritz Sonnenberg Rd" />
                <span asp-validation-for="Location" class="text-danger"></span>
            </div>

            <div class="form-group mb-4">
                <label asp-for="ImageUrl" class="control-label fw-bold"></label>
                <input asp-for="ImageUrl" class="form-control" placeholder="Paste image URL here" />
                @* ImageUrl is optional in the model, but validation helpers remain for consistency *@
                <span asp-validation-for="ImageUrl" class="text-danger"></span>
            </div>

            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary px-4 shadow-sm" />
                <a asp-action="Index" class="btn btn-secondary ms-2">Cancel</a>
            </div>
        </form>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @* Renders the partial view containing jQuery validation scripts to enable 
       client-side checks before server-side processing (Microsoft, 2023).
    *@
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}